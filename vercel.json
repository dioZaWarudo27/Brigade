{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://brigade-nylw.onrender.com/api/:path*" },
    { "source": "/login", "destination": "https://brigade-nylw.onrender.com/login" },
    { "source": "/logout", "destination": "https://brigade-nylw.onrender.com/logout" },
